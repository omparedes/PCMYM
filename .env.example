# === PCMYM — variables de entorno (PLANTILLA) ===
# Copia este archivo a `.env` y rellena con valores reales.
# `.env` está gitignored. NUNCA commitees valores reales.

# --- Supabase (cliente Angular: solo claves PÚBLICAS) ---
# La app Angular lee estas dos vía src/environments. La anon key es pública por diseño;
# la seguridad real la imponen las políticas RLS.
NG_APP_SUPABASE_URL=https://<project-ref>.supabase.co
NG_APP_SUPABASE_ANON_KEY=<anon-public-key>

# --- Supabase (SOLO server-side: Edge Functions / migraciones / CI) ---
# NUNCA exponer en el cliente. No prefijo NG_APP_ para que no llegue al bundle.
SUPABASE_PROJECT_REF=<project-ref>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
SUPABASE_DB_PASSWORD=<db-password>
SUPABASE_ACCESS_TOKEN=<personal-access-token-para-cli>

# --- IA (fase posterior — SOLO server-side, Edge Functions) ---
ANTHROPIC_API_KEY=<claude-api-key>

# --- Automatización / notificaciones (fases posteriores) ---
# WHATSAPP_CLOUD_TOKEN=<token>
# RESEND_API_KEY=<resend-key>
# N8N_WEBHOOK_URL=<url>
